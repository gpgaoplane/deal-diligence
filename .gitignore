# Secrets — never commit
.env
.env.*
!.env.example
*.pem
*.key

# multi-agent-collab runtime caches
.collab/.update-cache

# Claude Code local permission settings (per-developer; should not be shared)
.claude/settings.local.json

# n8n runtime data volume (per docker-compose.yml bind mount)
n8n/n8n-data/

# Generated memo outputs — regenerated per run; test-cases/ holds inputs, not outputs
outputs/*.json

# Node deps (we don't use npm install in repo root; only outside-sandbox scripts)
node_modules/

# Logs
*.log
