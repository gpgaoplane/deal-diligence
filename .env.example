# .env.example — template for local secrets.
# ---------------------------------------------------------------------
# Copy to .env and fill in real values. .env is gitignored.
# Phase 1 tasks 1.2–1.5 enumerate where each value comes from.
# ---------------------------------------------------------------------

# === n8n (local) ===
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=
GENERIC_TIMEZONE=America/Toronto

# === Alicloud DashScope (LLM + embeddings) ===
# Verify ALICLOUD_MODEL exists in your account via GET {BASE_URL}/models
ALICLOUD_API_KEY=
ALICLOUD_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
ALICLOUD_MODEL=qwen3.5-plus
ALICLOUD_EMBEDDING_MODEL=text-embedding-v4

# === Supabase ===
# Settings → API. SERVICE_ROLE_KEY bypasses RLS; treat as DB admin.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# === Langfuse Cloud ===
# Project must be named `sagard-deal-diligence` per design plan §2.12.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://us.cloud.langfuse.com

# === Slack ===
# Incoming webhook for #investment-team.
SLACK_WEBHOOK_URL=
