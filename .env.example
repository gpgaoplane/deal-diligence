# .env.example — template for local secrets.
# ---------------------------------------------------------------------
# Copy to .env and fill in real values. .env is gitignored.
# Phase 1 tasks 1.2–1.5 enumerate where each value comes from.
# ---------------------------------------------------------------------

# === n8n (local) ===
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=
GENERIC_TIMEZONE=America/Toronto

# === Alicloud DashScope (LLM chat completions) ===
# Verify ALICLOUD_MODEL exists in your account via GET {BASE_URL}/models
ALICLOUD_API_KEY=
ALICLOUD_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
ALICLOUD_MODEL=qwen3-max-preview
# ALICLOUD_EMBEDDING_MODEL=text-embedding-v4  # fallback if EMBEDDING_* swap breaks

# === Embeddings provider (decoupled from chat LLM per invariant I-6 swappability) ===
# Current: OpenRouter → nvidia/llama-nemotron-embed-vl-1b-v2:free (2048-dim, free tier).
# Swap by changing these three env vars and restarting docker compose.
# Fallback: point at Alicloud DashScope by setting BASE_URL to the ALICLOUD_BASE_URL
# and MODEL to text-embedding-v3 / v4.
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://openrouter.ai/api/v1
EMBEDDING_MODEL=nvidia/llama-nemotron-embed-vl-1b-v2:free

# === Supabase ===
# Settings → API. SERVICE_ROLE_KEY bypasses RLS; treat as DB admin.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# === Langfuse Cloud ===
# Project must be named `sagard-deal-diligence` per design plan §2.12.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://us.cloud.langfuse.com
# Alternate name (Langfuse Python SDK convention). Set EITHER LANGFUSE_BASE_URL
# OR LANGFUSE_HOST in .env; the workflow accepts both. Both default to US cloud.
# LANGFUSE_HOST=https://us.cloud.langfuse.com

# === Slack ===
# Incoming webhook for #investment-team.
SLACK_WEBHOOK_URL=
